generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  image     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  items     Item[]
}

model Item {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  size        String?
  image       String?
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  isAvailable Boolean  @default(true)
  tags        String[] @default([])
  createdAt   DateTime @default(now())
}

model AdminUser {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
}
