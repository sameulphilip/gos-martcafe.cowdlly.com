# Production — copy to Hostinger Node.js env vars (hPanel). Do NOT commit real values.

# Public site URL (QR code + NextAuth)
NEXT_PUBLIC_SITE_URL=https://gos-martcafe.cowdlly.com
NEXTAUTH_URL=https://gos-martcafe.cowdlly.com

# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-long-random-secret

# PostgreSQL — use Neon/Supabase free tier (Hostinger shared has MySQL, not Postgres)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

NODE_ENV=production
