# Copy to /opt/gos-mart/.env on VPS

DB_PASSWORD=change-me-strong-password
NEXTAUTH_SECRET=change-me-random-32-chars-minimum
NEXTAUTH_URL=https://gos-mart.cowdlly.com
NEXT_PUBLIC_SITE_URL=https://gos-mart.cowdlly.com

# true only on first deploy (creates tables + seed), then set false
RUN_DB_SETUP=true

# Admin login — set before first seed, or run deploy/vps/update-admin.sh later
# ADMIN_EMAIL=your@email.com
# ADMIN_PASSWORD=your-strong-password
